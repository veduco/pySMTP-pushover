{
  "gateway_config": {
    "smtp": {
      "queue_dir": "data/queue",
      "max_retry_backoff": 21600,
      "loglevel": "INFO",
      "default_route": "pushover",
      "disable_persistence": false,
      "max_backups": 50,
      "flood_enabled": false,
      "flood_limit": 60,
      "flood_window": "1m",
      "flood_scope": "ip",
      "listeners": [{"bind": "0.0.0.0:25", "starttls": false, "proxy_protocol": false}],
      "auth": {},
      "allowed_cidrs": [],
      "dedupe_enabled": false,
      "dedupe_window": "10m",
      "dedupe_keys": ["sender", "match_reason", "message"]
    },
    "pushover": {
      "attachments": true,
      "force_plaintext": false
    },
    "smarthost": {
      "globals": {
        "force_plaintext": false,
        "attachments": true
      },
      "aliases": {}
    },
    "routes": {}
  },
  "ui_config": {
    "timezone": "UTC",
    "date_format": "YYYY-MM-DD HH:mm:ss",
    "relative_time": true,
    "expand_adv": false,
    "trust_proxy": false,
    "vault_sort": "name_asc",
    "smtp_sort": "name_asc",
    "smarthost_sort": "alias_asc",
    "ui_loglevel": "INFO",
    "backend_mode": "local",
    "local_config_path": "",
    "primary_host": "",
    "remote_hosts": [],
    "remote_secrets": [],
    "allowed_cidrs": [],
    "trust_proxy_cidrs": [],
    "listeners": [{"bind": "0.0.0.0:8443", "https": true}]
  }
}

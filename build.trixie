FROM debian:trixie-slim

RUN  apt-get update
RUN  apt-get install -y \
         python3 \
         python3-pip \
         python3-requests \
         python3-cryptography \
         python3-aiosmtpd \
         python3-passlib \
         && apt-get clean

COPY ./smtp_pushover.py /smtp_pushover.py

CMD [ "python3", "/smtp_pushover.py" ]

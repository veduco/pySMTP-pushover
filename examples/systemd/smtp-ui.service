[Unit]
Description=SMTP to Pushover Control Panel
After=network.target smtp-gateway.service
Wants=smtp-gateway.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/smtp-pushover

# Environment variable declarations for runtime configuration path scopes
Environment="UI_CONFIG=/opt/smtp-pushover/ui_config.json"
Environment="PYTHONDONTWRITEBYTECODE=1"
Environment="PYTHONUNBUFFERED=1"

ExecStart=/usr/bin/python3 /opt/smtp-pushover/run_frontend.py

# Reliability and Shutdown
Restart=always
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=30

# Graceful hot reloads
ExecReload=/bin/kill -s SIGUSR2 $MAINPID

# Security Hardening
ProtectSystem=full
NoNewPrivileges=yes

[Install]
WantedBy=multi-user.target
